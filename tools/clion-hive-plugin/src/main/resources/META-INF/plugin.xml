<idea-plugin>
    <id>dev.hive.clion.hive-config</id>
    <name>Hive Config</name>
    <vendor email="devnull@hive.local">Hive</vendor>
    <description><![CDATA[
      CLion tool window that reads HiveFeatures.json and regenerates CMakeUserPresets.json.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.clion</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow
                id="HiveConfig"
                anchor="right"
                factoryClass="dev.hive.clion.config.HiveToolWindowFactory"
                icon="/META-INF/pluginIcon.svg"
                secondary="true"/>
        <notificationGroup id="Hive Config" displayType="BALLOON" isLogByDefault="true"/>
    </extensions>
</idea-plugin>
